        <a href="https://github.com/GABRIEL110290/" target="_blank" rel="noopener noreferrer"><img src="logos/github.png" class="pgn" alt="icono GitHub"></a>
        <a href="https://www.instagram.com/GABRIEL.GARAY.77377/" target="_blank" rel="noopener noreferrer"><img src="logos/instagram.png" class="pgn" alt="icono Instagram"></a>
    </footer>
</body>

<script src="./encriptador.js"></script>
</html>
